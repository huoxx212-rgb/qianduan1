<view class="page"><view class="shell"><button class="back-button" hover-class="back-button--hover" data-event-opts="{{[['tap',[['handleBack',['$event']]]]]}}" bindtap="__e"><view class="back-icon"></view></button><block wx:if="{{screen==='form'}}"><view class="form-panel"><view class="prompt-card"><textarea class="prompt-card__input" maxlength="-1" show-confirm-bar="{{false}}" data-event-opts="{{[['input',[['__set_model',['','poemText','$event',[]]]]]]}}" value="{{poemText}}" bindinput="__e"></textarea></view><button class="generate-button" hover-class="generate-button--hover" loading="{{loading}}" disabled="{{loading}}" data-event-opts="{{[['tap',[['handleGenerate',['$event']]]]]}}" bindtap="__e">{{''+(loading?texts.generating:texts.generate)+''}}</button></view></block><block wx:else><view class="result-panel"><image class="preview-image" src="{{previewImageUrl}}" mode="widthFix"></image></view></block></view></view>