<view class="community-page"><view class="community-shell"><scroll-view class="community-scroll" scroll-y="{{true}}"><view class="community-content"><view class="community-header"><text class="community-title">{{texts.pageTitle}}</text></view><view class="leaderboard-section"><view class="section-head"><text class="section-title">{{texts.leaderboardTitle}}</text><view class="section-pill"><view class="section-pill__icon"><view class="section-pill__bar"></view><view class="section-pill__bar section-pill__bar--mid"></view><view class="section-pill__bar section-pill__bar--high"></view></view><text class="section-pill__text">{{texts.fullBoard}}</text></view></view><view class="leaderboard-list"><block wx:for="{{leaderboard}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="leaderboard-list__item"><community-rank-item vue-id="{{'d24888ba-1-'+__i0__}}" item="{{item}}" bind:__l="__l"></community-rank-item></view></block></view></view><view class="challenge-section"><view class="section-head section-head--challenge"><text class="section-title section-title--challenge">{{texts.challengeTitle}}</text><text class="section-link">{{texts.viewAll}}</text></view><view class="challenge-list"><block wx:for="{{challenges}}" wx:for-item="item" wx:for-index="__i1__" wx:key="id"><navigator class="challenge-list__item" url="{{item.route}}" hover-class="none"><community-challenge-card vue-id="{{'d24888ba-2-'+__i1__}}" item="{{item}}" bind:__l="__l"></community-challenge-card></navigator></block></view></view></view></scroll-view><view class="community-tabbar"><block wx:for="{{tabs}}" wx:for-item="tab" wx:for-index="__i2__" wx:key="key"><view data-event-opts="{{[['tap',[['handleTabTap',['$0'],[[['tabs','key',tab.key]]]]]]]}}" class="{{['community-tabbar__item',(tab.active)?'community-tabbar__item--active':'']}}" bindtap="__e"><block wx:if="{{tab.key==='home'}}"><view class="tab-icon tab-icon--home"><view class="tab-icon__home-roof"></view><view class="tab-icon__home-body"></view></view></block><block wx:else><block wx:if="{{tab.key==='discover'}}"><view class="tab-icon tab-icon--discover"><view class="tab-icon__discover-ring"></view><view class="tab-icon__discover-smile"></view></view></block><block wx:else><view class="tab-icon tab-icon--profile"><view class="tab-icon__profile-head"></view><view class="tab-icon__profile-body"></view></view></block></block></view></block></view></view></view>