<view class="page"><view class="shell"><button class="back-button" hover-class="back-button--hover" data-event-opts="{{[['tap',[['handleBack',['$event']]]]]}}" bindtap="__e"><view class="back-icon"></view></button><block wx:if="{{screen==='form'}}"><view class="form-panel"><block wx:for="{{fields}}" wx:for-item="field" wx:for-index="__i0__" wx:key="key"><view class="field-block"><text class="field-label">{{field.label+":"}}</text><textarea class="field-input" style="{{'height:'+(field.height)+';'}}" maxlength="-1" show-confirm-bar="{{false}}" data-event-opts="{{[['input',[['__set_model',['$0','$1','$event',[]],['form',[['fields','key',field.key,'key']]]]]]]}}" value="{{form[field.key]}}" bindinput="__e"></textarea></view></block><button class="generate-button" hover-class="generate-button--hover" loading="{{loading}}" disabled="{{loading}}" data-event-opts="{{[['tap',[['handleGenerate',['$event']]]]]}}" bindtap="__e">{{''+(loading?'生成中':'点击生成')+''}}</button></view></block><block wx:else><view class="result-panel"><image class="painting-image" src="{{result.imageUrl}}" mode="widthFix"></image></view></block></view></view>