<view class="container">
  <text class="title">以诗入画</text>
  <text class="desc">输入一句诗，AI 将生成符合诗词意境的山水画。</text>
  <textarea value="{{poem}}" bindinput="onInput" placeholder="请输入一句诗词，例如：千山鸟飞绝，万径人踪灭。"></textarea>
  <view class="actions">
    <button bindtap="useExample" class="btn-secondary">示例诗句</button>
    <button bindtap="clearInput" class="btn-secondary">清空</button>
  </view>
  <button class="primary-btn" bindtap="startGenerate">开始生成</button>
</view>
