.container { padding: 40rpx; background-color: #F5F5DC; min-height: 100vh; }
.title { font-size: 40rpx; font-weight: bold; margin-bottom: 20rpx; display: block; }
.desc { font-size: 28rpx; color: #666; display: block; margin-bottom: 40rpx; }
textarea { width: 100%; background: #fff; padding: 20rpx; border-radius: 8rpx; height: 160rpx; box-sizing: border-box; margin-bottom: 30rpx; }
.actions { display: flex; justify-content: space-between; margin-bottom: 40rpx; }
.btn-secondary { width: 45%; font-size: 28rpx; background: #e0e0e0; }
.primary-btn { width: 100%; background: #333; color: #fff; font-size: 32rpx; border-radius: 8rpx; }
