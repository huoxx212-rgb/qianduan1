.container { padding: 40rpx; background-color: #F5F5DC; min-height: 100vh;}
.content { background: #fff; padding: 40rpx; border-radius: 16rpx;}
.title { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 30rpx; display: block; text-align: center;}
.paragraph { font-size: 28rpx; color: #555; line-height: 1.8; margin-bottom: 20rpx; display: block; text-indent: 56rpx;}
