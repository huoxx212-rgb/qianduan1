.container { padding: 30rpx; background-color: #F5F5DC; min-height: 100vh;}
.image-wrapper { width: 100%; border-radius: 12rpx; overflow: hidden; margin-bottom: 30rpx; background: #eaeaea;}
.result-img { width: 100%; display: block; }
.info-card { background: #fff; padding: 30rpx; border-radius: 12rpx; margin-bottom: 40rpx;}
.info-label { font-size: 26rpx; color: #999; font-weight: bold; margin-top: 10rpx; display: block;}
.info-text { font-size: 28rpx; color: #333; margin-bottom: 20rpx; display: block;}
.btn-group { display: flex; justify-content: space-between; flex-wrap: wrap;}
.btn { width: 30%; font-size: 24rpx; padding: 0; background: #fff; color: #333;}
