.container { padding: 30rpx; background-color: #F5F5DC; min-height: 100vh;}
.page-title { font-size: 40rpx; font-weight: bold; margin-bottom: 40rpx; display: block;}
.form-group { margin-bottom: 30rpx; }
.label { font-size: 28rpx; color: #333; margin-bottom: 10rpx; display: block; }
textarea { width: 100%; background: #fff; padding: 20rpx; border-radius: 8rpx; height: 120rpx; box-sizing: border-box;}
.actions { display: flex; justify-content: space-between; margin-bottom: 40rpx; }
.btn-secondary { width: 45%; font-size: 28rpx; background: #e0e0e0; }
.btn-primary { width: 100%; background: #333; color: #fff; font-size: 32rpx; border-radius: 8rpx;}
