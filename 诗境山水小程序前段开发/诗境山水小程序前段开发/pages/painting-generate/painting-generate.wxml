<view class="container">
  <text class="page-title">文脉生画</text>
  <view class="form-group">
    <text class="label">作品历史背景 (history)</text>
    <textarea data-field="history" value="{{formData.history}}" bindinput="onInput" placeholder="请输入古画历史背景"></textarea>
  </view>
  <view class="form-group">
    <text class="label">画面内容描述 (content)</text>
    <textarea data-field="content" value="{{formData.content}}" bindinput="onInput" placeholder="请输入画面内容"></textarea>
  </view>
  <view class="form-group">
    <text class="label">情绪意境描述 (mood)</text>
    <textarea data-field="mood" value="{{formData.mood}}" bindinput="onInput" placeholder="请输入情绪意境"></textarea>
  </view>
  <view class="form-group">
    <text class="label">关联诗句 (poem)</text>
    <textarea data-field="poem" value="{{formData.poem}}" bindinput="onInput" placeholder="请输入关联诗句"></textarea>
  </view>
  <view class="actions">
    <button class="btn-secondary" bindtap="useExample">使用示例</button>
    <button class="btn-secondary" bindtap="clearInput">清空内容</button>
  </view>
  <button class="btn-primary" bindtap="submitTask">开始生成</button>
</view>
