.container { padding: 20rpx; background-color: #F5F5DC; min-height: 100vh;}
.item { display: flex; background: #fff; padding: 20rpx; border-radius: 12rpx; margin-bottom: 20rpx;}
.thumb { width: 120rpx; height: 120rpx; border-radius: 8rpx; margin-right: 20rpx; background: #eee;}
.info { flex: 1; display: flex; flex-direction: column; justify-content: center;}
.title { font-size: 30rpx; color: #333; font-weight: bold; margin-bottom: 10rpx;}
.meta { font-size: 24rpx; color: #999;}
