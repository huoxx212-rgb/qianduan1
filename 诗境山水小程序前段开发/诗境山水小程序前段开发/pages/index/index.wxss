.container { padding: 40rpx; background-color: #F5F5DC; min-height: 100vh; }
.header { margin-bottom: 60rpx; text-align: center; }
.title { font-size: 48rpx; font-weight: bold; color: #333; display: block; margin-bottom: 20rpx;}
.desc { font-size: 28rpx; color: #666; }
.card { background: #fff; padding: 40rpx; border-radius: 16rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); }
.card-title { font-size: 36rpx; font-weight: bold; display: block; margin-bottom: 10rpx; color: #333;}
.card-desc { font-size: 24rpx; color: #999; }
.footer-links { display: flex; justify-content: center; margin-top: 60rpx; }
.text-btn { font-size: 28rpx; color: #555; background: none; }
.text-btn::after { border: none; }
