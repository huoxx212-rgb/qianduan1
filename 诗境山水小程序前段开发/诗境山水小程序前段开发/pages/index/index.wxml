<view class="container">
  <view class="header">
    <text class="title">诗境山水</text>
    <text class="desc">输入诗词或古画信息，生成符合意境的山水画</text>
  </view>
  <view class="card-list">
    <view class="card" bindtap="navTo" data-url="/pages/poem-generate/poem-generate">
      <text class="card-title">以诗入画</text>
      <text class="card-desc">输入单句诗词生成意境山水</text>
    </view>
    <view class="card" bindtap="navTo" data-url="/pages/painting-generate/painting-generate">
      <text class="card-title">文脉生画</text>
      <text class="card-desc">输入古画历史与内容生成画作</text>
    </view>
  </view>
  <view class="footer-links">
    <button class="text-btn" bindtap="navTo" data-url="/pages/history/history">历史记录</button>
    <button class="text-btn" bindtap="navTo" data-url="/pages/about/about">关于项目</button>
  </view>
</view>
